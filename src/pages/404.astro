---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <div class="text-8xl font-display font-bold gradient-text mb-4">404</div>
      <h1 class="text-2xl font-display font-bold mb-2">Page Not Found</h1>
      <p class="text-muted mb-8">The page you are looking for does not exist.</p>
      <a href="/" class="inline-flex px-8 py-4 bg-gradient-to-r from-purple to-cyan text-white rounded-xl font-medium hover:shadow-lg hover:shadow-purple/25 transition-all">
        Go Home
      </a>
    </div>
  </main>
</BaseLayout>
