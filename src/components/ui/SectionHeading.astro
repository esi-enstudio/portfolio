---
export interface Props {
  title: string;
  subtitle?: string;
  tag?: string;
  tagKey?: string;
  titleKey?: string;
  subtitleKey?: string;
}

const { title, subtitle, tag, tagKey, titleKey, subtitleKey } = Astro.props;
---

<div class="text-center mb-16 md:mb-20">
  {tag && (
    <span class="inline-block px-4 py-1.5 text-xs font-mono font-medium text-purple-light bg-purple/10 rounded-full border border-purple/20 mb-4" data-i18n={tagKey}>
      {tag}
    </span>
  )}
  <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold mb-4">
    <span class="gradient-text" data-i18n={titleKey}>{title}</span>
  </h2>
  {subtitle && (
    <p class="text-muted text-base md:text-lg max-w-2xl mx-auto leading-relaxed" data-i18n={subtitleKey}>
      {subtitle}
    </p>
  )}
</div>
