---
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="gallery" class="relative py-24 md:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      tag="Gallery"
      title="Moments & Memories"
      subtitle="A visual collection of moments from my professional journey."
      tagKey="gallery.tag"
      titleKey="gallery.title"
      subtitleKey="gallery.subtitle"
    />

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {[...Array(8)].map((_, i) => (
        <div
          class={`group glass rounded-2xl overflow-hidden cursor-pointer hover:neon-glow transition-all duration-500 ${i === 0 ? 'col-span-2 row-span-2' : ''}`}
        >
          <div class={`${i === 0 ? 'h-80' : 'h-48'} bg-gradient-to-br from-purple/20 to-cyan/20 flex items-center justify-center relative overflow-hidden`}>
            <div class="absolute inset-0 bg-gradient-to-br from-purple/30 to-cyan/30 group-hover:scale-110 transition-transform duration-500"></div>
            <span class="relative text-6xl font-display font-bold text-white/10 group-hover:text-white/20 transition-all duration-500">
              {String(i + 1).padStart(2, '0')}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
