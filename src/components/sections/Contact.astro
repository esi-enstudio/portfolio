---
import SectionHeading from '../ui/SectionHeading.astro';
import { SOCIAL } from '../../lib/constants';
---

<section id="contact" class="relative py-24 md:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-deep-black via-purple/5 to-deep-black pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <SectionHeading
      tag="Contact"
      title="Let's Work Together"
      subtitle="Have a project in mind? Let's discuss how I can help bring your ideas to life."
      tagKey="contact.tag"
      titleKey="contact.title"
      subtitleKey="contact.subtitle"
    />

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <div>
        <form id="contact-form" class="space-y-6">
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium mb-2 text-muted" data-i18n="contact.name_label">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-xl glass text-foreground placeholder:text-muted/50 focus:outline-none focus:border-purple/50 focus:ring-1 focus:ring-purple/30 transition-all duration-300"
                placeholder="Your name"
                data-i18n-placeholder="contact.name_label"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium mb-2 text-muted" data-i18n="contact.email_label">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl glass text-foreground placeholder:text-muted/50 focus:outline-none focus:border-purple/50 focus:ring-1 focus:ring-purple/30 transition-all duration-300"
                placeholder="your@email.com"
                data-i18n-placeholder="contact.email_label"
              />
            </div>
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium mb-2 text-muted">Phone (optional)</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-3 rounded-xl glass text-foreground placeholder:text-muted/50 focus:outline-none focus:border-purple/50 focus:ring-1 focus:ring-purple/30 transition-all duration-300"
              placeholder="+1 (555) 000-0000"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium mb-2 text-muted">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-xl glass text-foreground placeholder:text-muted/50 focus:outline-none focus:border-purple/50 focus:ring-1 focus:ring-purple/30 transition-all duration-300 resize-none"
              placeholder="Tell me about your project..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full px-8 py-4 bg-gradient-to-r from-purple to-cyan text-white font-medium rounded-xl hover:shadow-lg hover:shadow-purple/25 transition-all duration-300 cursor-pointer hover:-translate-y-0.5"
          >
            Send Message
          </button>
        </form>

        <div id="form-success" class="hidden glass rounded-2xl p-8 text-center">
          <div class="w-16 h-16 rounded-full bg-green-500/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-bold mb-2">Message Sent!</h3>
          <p class="text-muted text-sm">Thank you for reaching out. I'll get back to you within 24 hours.</p>
        </div>
      </div>

      <div class="space-y-8">
        <div class="glass rounded-2xl p-8">
          <h3 class="text-lg font-display font-bold mb-6">Contact Information</h3>
          <div class="space-y-5">
            {[
              { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', label: 'Email', value: 'hello@sadekin.dev' },
              { icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', label: 'Phone', value: '+880 (1XXX) XXX-XXX' },
              { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', label: 'Location', value: 'Bangladesh' },
            ].map((info) => (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-purple/10 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={info.icon} />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-muted">{info.label}</p>
                  <p class="text-sm font-medium">{info.value}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="glass rounded-2xl p-8">
          <h3 class="text-lg font-display font-bold mb-4">Quick Connect</h3>
          <div class="flex gap-3">
            {[
              { href: SOCIAL.github, label: 'GitHub' },
              { href: SOCIAL.linkedin, label: 'LinkedIn' },
              { href: SOCIAL.twitter, label: 'Twitter' },
            ].map((link) => (
              <a
                href={link.href}
                class="flex-1 px-4 py-3 rounded-xl bg-white/5 text-center text-sm text-muted hover:text-cyan hover:bg-white/10 transition-all duration-300"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contact-form');
    const success = document.getElementById('form-success');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      form.style.display = 'none';
      success?.classList.remove('hidden');
    });
  });
</script>
