---
import SectionHeading from '../ui/SectionHeading.astro';
import { EXPERIENCE, EDUCATION, CERTIFICATIONS } from '../../lib/constants';
---

<section id="experience" class="relative py-24 md:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      tag="Experience"
      title="Professional Journey"
      subtitle="A timeline of my professional growth and accomplishments."
      tagKey="experience.tag"
      titleKey="experience.title"
      subtitleKey="experience.subtitle"
    />

    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <h3 class="text-xl font-display font-bold mb-8 flex items-center gap-3">
          <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Work Experience
        </h3>

        <div class="space-y-6">
          {EXPERIENCE.map((exp) => (
            <div class="glass rounded-2xl p-6 hover:neon-glow transition-all duration-300 group">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                <div>
                  <h4 class="font-display font-bold group-hover:gradient-text transition-all">{exp.position}</h4>
                  <p class="text-sm text-cyan">{exp.company}</p>
                </div>
                <span class="text-xs font-mono text-muted bg-white/5 px-3 py-1 rounded-full">{exp.duration}</span>
              </div>
              <p class="text-sm text-muted leading-relaxed mb-3">{exp.description}</p>
              <ul class="space-y-1.5">
                {exp.achievements.map((ach) => (
                  <li class="text-xs text-muted flex items-start gap-2">
                    <span class="text-cyan mt-0.5 shrink-0">▹</span>
                    {ach}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <div class="space-y-8">
        <div>
          <h3 class="text-xl font-display font-bold mb-6 flex items-center gap-3">
            <svg class="w-6 h-6 text-purple-light" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 7l-9-5 9-5 9 5-9 5z" />
            </svg>
            Education
          </h3>

          <div class="space-y-4">
            {EDUCATION.map((edu) => (
              <div class="glass rounded-xl p-5 hover:neon-glow transition-all duration-300">
                <h4 class="font-semibold text-sm">{edu.degree}</h4>
                <p class="text-xs text-cyan mt-1">{edu.institution}</p>
                <div class="flex items-center gap-3 mt-2">
                  <span class="text-xs font-mono text-muted">{edu.year}</span>
                  <span class="w-1 h-1 rounded-full bg-muted"></span>
                  <span class="text-xs text-purple-light">{edu.result}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h3 class="text-xl font-display font-bold mb-6 flex items-center gap-3">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
            Certifications
          </h3>

          <div class="space-y-4">
            {CERTIFICATIONS.map((cert) => (
              <a
                href={cert.link}
                class="block glass rounded-xl p-5 hover:neon-glow transition-all duration-300 group"
              >
                <h4 class="font-semibold text-sm group-hover:gradient-text transition-all">{cert.title}</h4>
                <p class="text-xs text-muted mt-1">{cert.issuer}</p>
                <span class="text-xs font-mono text-purple-light mt-2 block">{cert.year}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
