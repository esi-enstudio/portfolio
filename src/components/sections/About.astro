---
import SectionHeading from '../ui/SectionHeading.astro';
import { EXPERIENCE } from '../../lib/constants';
---

<section id="about" class="relative py-24 md:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-deep-black via-purple/5 to-deep-black pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <SectionHeading
      tag="About Me"
      title="Crafting Code, Building Dreams"
      subtitle="A passionate developer building digital products that make a difference."
      tagKey="about.tag"
      titleKey="about.title"
      subtitleKey="about.subtitle"
    />

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-20">
      <div class="relative">
        <div class="relative w-64 h-64 md:w-80 md:h-80 mx-auto rounded-2xl glass p-1 overflow-hidden">
          <div class="w-full h-full rounded-2xl bg-gradient-to-br from-purple/30 to-cyan/30 flex items-center justify-center">
            <div class="text-7xl font-display font-bold gradient-text">SE</div>
          </div>
        </div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 rounded-2xl glass flex items-center justify-center text-3xl animate-float" style="animation-delay: 1s">
          🚀
        </div>
        <div class="absolute -top-4 -left-4 w-20 h-20 rounded-full glass flex items-center justify-center text-2xl animate-float">
          💡
        </div>
      </div>

      <div>
        <h3 class="text-2xl md:text-3xl font-display font-bold mb-6">
          <span data-i18n="about.greeting">Hi, I'm</span> <span class="gradient-text">Sadekin Islam Emil</span>
        </h3>
        <div class="space-y-4 text-muted leading-relaxed">
          <p data-i18n="about.para1">
            I am a Full Stack Developer with experience crafting
            digital solutions that blend creativity with technical excellence.
            My journey in tech started with curiosity and evolved into a passion
            for building products that people love to use.
          </p>
          <p data-i18n="about.para2">
            Specializing in Laravel, Astro JS, and modern JavaScript frameworks,
            I bring ideas to life through clean code, thoughtful architecture,
            and pixel-perfect design. Every project is an opportunity to push
            boundaries and create something extraordinary.
          </p>
          <p data-i18n="about.para3">
            When I am not coding, you will find me exploring new technologies,
            contributing to open source, or sharing knowledge through technical
            writing and mentoring.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-8">
          {[
            { key: 'about.name', label: 'Name', value: 'Sadekin Islam Emil' },
            { key: 'about.email', label: 'Email', value: 'hello@sadekin.dev' },
            { key: 'about.location', label: 'Location', value: 'Bangladesh' },
            { key: 'about.availability', label: 'Availability', value: 'Open to Work' },
          ].map((item) => (
            <div class="glass rounded-xl p-4">
              <span class="text-xs text-muted uppercase tracking-wider" data-i18n={item.key}>{item.label}</span>
              <p class="text-sm font-medium mt-1">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div>
      <h3 class="text-2xl font-display font-bold text-center mb-12">
        <span class="gradient-text">Career Journey</span>
      </h3>

      <div class="relative">
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-purple via-cyan to-purple transform md:-translate-x-px"></div>

        <div class="space-y-12">
          {EXPERIENCE.map((exp, index) => (
            <div class={`relative flex flex-col md:flex-row gap-6 md:gap-12 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
              <div class="absolute left-4 md:left-1/2 w-3 h-3 bg-purple rounded-full transform -translate-x-1/2 mt-2 border-2 border-deep-black shadow-lg shadow-purple/30"></div>

              <div class={`flex-1 ${index % 2 === 0 ? 'md:text-right md:pr-12' : 'md:pl-12'}`}>
                <div class="pl-10 md:pl-0 glass rounded-2xl p-6 hover:neon-glow transition-all duration-300">
                  <span class="text-xs font-mono text-purple-light">{exp.duration}</span>
                  <h4 class="text-lg font-bold font-display mt-1">{exp.position}</h4>
                  <p class="text-sm text-cyan">{exp.company}</p>
                  <p class="text-sm text-muted mt-3 leading-relaxed">{exp.description}</p>
                  <ul class="mt-3 space-y-1">
                    {exp.achievements.map((ach) => (
                      <li class="text-xs text-muted flex items-start gap-2">
                        <span class="text-cyan mt-0.5">▹</span>
                        {ach}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <div class="hidden md:block flex-1"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
