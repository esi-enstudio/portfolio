---
import SectionHeading from '../ui/SectionHeading.astro';
import { STATS } from '../../lib/constants';
---

<section id="achievements" class="relative py-24 md:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      tag="Achievements"
      title="Numbers Speak Volumes"
      subtitle="The impact of my work measured in milestones and metrics."
      tagKey="achievements.tag"
      titleKey="achievements.title"
      subtitleKey="achievements.subtitle"
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {STATS.map((stat, index) => (
        <div
          class="glass rounded-2xl p-8 md:p-10 text-center hover:neon-glow transition-all duration-500 group relative overflow-hidden"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <div class="absolute inset-0 bg-gradient-to-br from-purple/5 to-cyan/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <div class="text-4xl md:text-5xl font-display font-bold gradient-text mb-2 counter" data-target={stat.value}>
              0
            </div>
            <span class="text-sm text-muted">{stat.label}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
